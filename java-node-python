## 5. Functions

| Concept | Java | Node.js | Python |
|---|---|---|---|
| Basic | `public static int add(int a, int b)` | `function add(a, b)` | `def add(a, b):` |
| Arrow/Lambda | `(a, b) -> a + b` | `(a, b) => a + b` | `lambda a, b: a + b` |
| Default Params | Use overloading | `add(a, b=10)` | `def add(a, b=10):` |
| Varargs | `void f(int... args)` | `function f(...args)` | `def f(*args):` |
| Return Multiple | Return array/object | Return array/object | `return a, b` |

### 🧪 Practice
```java
// Java
// Basic
public static int add(int a, int b) { return a + b; }

// Lambda
Function<Integer, Integer> sq = x -> x * x;
System.out.println(sq.apply(5)); // 25

// Default (via overloading)
static String greet(String name) { return greet(name, "Hello"); }
static String greet(String name, String msg) { return msg + " " + name; }

// Varargs
static int sum(int... nums) {
    int total = 0;
    for (int n : nums) total += n;
    return total;
}
System.out.println(sum(1, 2, 3, 4)); // 10
```
```javascript
// Node.js
// Basic
function add(a, b) { return a + b; }

// Arrow
const sq = x => x * x;
console.log(sq(5)); // 25

// Default
function greet(name, msg = "Hello") { return `${msg} ${name}`; }
console.log(greet("Mani")); // Hello Mani

// Rest/Varargs
function sum(...nums) { return nums.reduce((a, b) => a + b, 0); }
console.log(sum(1, 2, 3, 4)); // 10
```
```python
# Python
# Basic
def add(a, b): return a + b

# Lambda
sq = lambda x: x ** 2
print(sq(5))  # 25

# Default
def greet(name, msg="Hello"): return f"{msg} {name}"
print(greet("Mani"))  # Hello Mani

# Varargs
def total(*nums): return sum(nums)
print(total(1, 2, 3, 4))  # 10
```

